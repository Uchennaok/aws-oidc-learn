apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: vault-ingress
  namespace: vault
  annotations:
    kubernetes.io/ingress.class: "gce"
    networking.gke.io/managed-certificates: vault-cert
spec:
  defaultBackend:
    service:
      name: vault-ui
      port:
        number: 8200
---
apiVersion: cloud.google.com/v1
kind: BackendConfig
metadata:
  name: vault-backendconfig
  namespace: vault
spec:
  healthCheck:
    checkIntervalSec: 10
    timeoutSec: 5
    healthyThreshold: 1
    unhealthyThreshold: 3
    type: HTTP
    requestPath: /v1/sys/health
    port: 8200
---
apiVersion: networking.gke.io/v1
kind: ManagedCertificate
metadata:
  name: vault-cert
  namespace: vault
spec:
  domains:
    - vault.sf-test-andres.com